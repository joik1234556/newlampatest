# =============================================================================
# Lampa Easy-Mod — шаблон переменных окружения
# Скопируйте в .env и заполните значения:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# ОБЯЗАТЕЛЬНО — без этого ключа стриминг не работает
# Получить: https://torbox.app → настройки аккаунта → API
# -----------------------------------------------------------------------------
TORBOX_API_KEY=your-torbox-api-key-here

# -----------------------------------------------------------------------------
# Redis (при запуске через Docker Compose заполняется автоматически)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Jackett — агрегатор торрент-трекеров (опционально, но рекомендуется)
# При запуске через Docker Compose URL заполняется автоматически.
# API Key берётся из веб-интерфейса Jackett: http://<ip>:9117
# -----------------------------------------------------------------------------
JACKETT_URL=http://localhost:9117
JACKETT_API_KEY=

# -----------------------------------------------------------------------------
# Torrentio — публичный источник торрентов
# Менять не нужно, если только torrentio.strem.fun недоступен из вашей сети
# -----------------------------------------------------------------------------
TORRENTIO_BASE=https://torrentio.strem.fun

# -----------------------------------------------------------------------------
# Кеши (TTL в секундах)
# -----------------------------------------------------------------------------
VARIANTS_CACHE_TTL=1800       # список вариантов — 30 мин
DIRECT_URL_CACHE_TTL=3600     # прямые ссылки — 1 час
JOB_TTL=7200                  # задачи стриминга — 2 часа

# -----------------------------------------------------------------------------
# Стратегия опроса TorBox
# -----------------------------------------------------------------------------
TORBOX_POLL_MAX_SECONDS=180   # максимальное время ожидания — 3 мин
TORBOX_POLL_FAST_SECONDS=30   # первые 30 с — частый опрос
TORBOX_POLL_FAST_INTERVAL=1   # интервал частого опроса (сек)
TORBOX_POLL_SLOW_INTERVAL=5   # интервал медленного опроса (сек)

# -----------------------------------------------------------------------------
# Логирование: DEBUG | INFO | WARNING | ERROR
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Прокси M3U8-плейлистов (опционально)
# -----------------------------------------------------------------------------
PROXY_M3U8_ENABLED=1

# -----------------------------------------------------------------------------
# ScrapingBee — используется для обхода защиты на Zetflix (опционально)
# Если ключ не задан, используется cloudscraper
# -----------------------------------------------------------------------------
SCRAPINGBEE_API_KEY=
USE_SCRAPINGBEE=1

# -----------------------------------------------------------------------------
# DemoProvider — включать ТОЛЬКО при разработке/тестировании
# -----------------------------------------------------------------------------
ENABLE_DEMO_PROVIDER=0
