# Copy this file to .env and fill in the values
TORBOX_API_KEY=your-torbox-api-key-here

# Optional — override cache TTLs (seconds)
VARIANTS_CACHE_TTL=1800
DIRECT_URL_CACHE_TTL=7200

# Optional — TorBox polling
STREAM_POLL_INTERVAL=5
STREAM_POLL_TIMEOUT=240

# Optional — log level (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO
