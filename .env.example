# Easy-Mod Backend — environment variables

# CF Workers proxy (required for HDRezka, Zetflix, Collaps, Bazon)
CF_PROXY_URL=https://lampaproxy.egorkorotkov5.workers.dev/

# ScrapingBee API key (optional; used as priority scraper for Zetflix when set)
SCRAPINGBEE_API_KEY=

# HDRezka mirrors (comma-separated)
HDREZKA_MIRRORS=https://rezka.ag,https://hdrezka.ag,https://rezka.me

# Zetflix mirrors (comma-separated)
ZETFLIX_MIRRORS=https://zetflix.org,https://zetflix.cc

# Server port
PORT=8000
