# Copy this file to .env and fill in the values
TORBOX_API_KEY=your-torbox-api-key-here

# Redis connection (required for production; falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379/0

# Cache TTL (seconds)
VARIANTS_CACHE_TTL=1800
DIRECT_URL_CACHE_TTL=7200
JOB_TTL=7200

# TorBox polling strategy
TORBOX_POLL_MAX_SECONDS=180
TORBOX_POLL_FAST_SECONDS=30
TORBOX_POLL_FAST_INTERVAL=2
TORBOX_POLL_SLOW_INTERVAL=5

# Optional — log level (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO

# Jackett integration (optional — enables real torrent search in /variants and /torbox/search)
# Install Jackett from https://github.com/Jackett/Jackett and set the values below.
# If not set, the server uses Torrentio (public, no config needed) when a TMDB ID is
# available, and falls back to demo data otherwise.
JACKETT_URL=http://localhost:9117
JACKETT_API_KEY=your-jackett-api-key-here

# DemoProvider — set to "1" in development/testing only; must be "0" in production
# When disabled (0), /variants returns an empty list if no real providers find results.
ENABLE_DEMO_PROVIDER=0
